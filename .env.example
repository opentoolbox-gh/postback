# ── PostgreSQL ────────────────────────────────────────────────────────────────
PGHOST=db.example.com
PGPORT=5432
PGDATABASE=mydb
PGUSER=postgres
PGPASSWORD=changeme

# ── Storage backend ───────────────────────────────────────────────────────────
# "local"  → write to a mounted volume (default)
# "rsync"  → rsync over SSH to a remote server
STORAGE_BACKEND=local

# [local] Host directory that gets mounted into the container as /backup.
# The three tier directories (hourly/, 6h/, daily/) are created automatically.
LOCAL_BACKUP_PATH=./backups

# [rsync] Remote server details (only needed when STORAGE_BACKEND=rsync)
# RSYNC_HOST=backups.example.com
# RSYNC_USER=backups
# RSYNC_PATH=/var/backups/postgres
# RSYNC_PORT=22
# RSYNC_SSH_KEY_PATH=/etc/postback/rsync_key

# ── Encryption (optional) ─────────────────────────────────────────────────────
# Generate a key pair: age-keygen -o key.txt
# The public key (age1...) encrypts. Keep the private key offline for restores.
# ENCRYPTION_PUBLIC_KEY=age1ql3z7hjy54pw3hyww5ayyfg7zqgvc7w3j2elw8zmrj2kg5sfn9aqmcac8p

# ── Slack notifications (optional) ───────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=#db-alerts
# SLACK_NOTIFY_ON=success,failure

# ── Optional ──────────────────────────────────────────────────────────────────
RUST_LOG=info
