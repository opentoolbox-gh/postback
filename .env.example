# ── PostgreSQL (external host) ────────────────────────────────────────────────
PGHOST=db.example.com
PGPORT=5432
PGDATABASE=mydb
PGUSER=postgres
PGPASSWORD=changeme

# ── Google Drive ──────────────────────────────────────────────────────────────
# Folder ID from the Drive URL:
# https://drive.google.com/drive/folders/<GDRIVE_FOLDER_ID>
GDRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Absolute path to your service account JSON key on the HOST machine
SA_KEY_PATH=/etc/postback/sa_key.json

# ── Slack notifications (optional) ───────────────────────────────────────────
# Bot token from https://api.slack.com/apps → OAuth & Permissions → Bot Token
# Required scope: chat:write
# SLACK_BOT_TOKEN=xoxb-...

# Channel ID or name (e.g. C1234567890 or #db-alerts)
# SLACK_CHANNEL=#db-alerts

# Comma-separated list of events to notify on.
# Available: start, auth, success, failure, retention
# Default: success,failure
# SLACK_NOTIFY_ON=success,failure

# ── Optional ──────────────────────────────────────────────────────────────────
RUST_LOG=info
